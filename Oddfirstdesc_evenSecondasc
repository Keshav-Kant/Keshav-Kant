#include<stdio.h>
int main(){
	int n,i,j,min,min1;
	scanf("%d",&n);
	int a[n];
	
	for(i=0;i<n;i++)
		scanf("%d",&a[i]);
	
	for(i=0;i<n;i++){
		for(j=i+1;j<n;j++){
			if(a[i]>a[j]){
			int temp=a[i];
			a[i]=a[j];
			a[j]=temp;
		}	
		}
	}
	
for(i=n;i>=0;i--){
	if(a[i]%2>0){
		min1=a[i];
		if(a[i]>min1){
			min1=a[i];
		}
		if(a[i]%2!=0){
			if(a[i]>min1){
				min1=a[i];
			}
		}
	printf("%d ",min1);
	}	
}	

	for(i=0;i<n;i++){
		if(a[i]%2==0){
			min=a[i];
	}
	
	if(a[i]%2==0){
		if(a[i]<min){
			min=a[i];
		}
		printf("%d ",min);
	}

}

}
